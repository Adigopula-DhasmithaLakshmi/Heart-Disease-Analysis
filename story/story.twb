    <dashboard name='Story 1' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Heart Disease Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' preset-index='1' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='1' param='vert' removable='false' type-v2='layout-flow' w='98400' x='800' y='1000'>
            <zone h='5250' id='3' type-v2='title' w='98400' x='800' y='1000' />
            <zone h='12625' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98400' x='800' y='6250' />
            <zone h='80125' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98400' x='800' y='18875'>
              <flipboard active-id='9' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Gender vs Heart Disease' captured-sheet='Sheet 1' id='1' />
                  <story-point caption='Age vs Heart Disease' captured-sheet='Sheet 2' id='2' />
                  <story-point caption='Diabetic vs Stroke' captured-sheet='Sheet 3' id='3' />
                  <story-point caption='Impact of Smoking and Alcohol on Heart Disease' captured-sheet='Sheet 4' id='4' />
                  <story-point caption='Other Health Diseases vs Stroke' captured-sheet='Sheet 5' id='5' />
                  <story-point caption='Race Wise Heart Disease' captured-sheet='Sheet 6' id='6' />
                  <story-point caption='General Health vs Heart Disease' captured-sheet='Sheet 7' id='7' />
                  <story-point caption='Physical Activity vs Heart Disease' captured-sheet='Sheet 8' id='8' />
                  <story-point caption='Age and BMI vs Diabetic' captured-sheet='Sheet 9' id='9' />
                  <story-point caption='People Got Stroke Suffering from Heart Disease and Diabetic' captured-sheet='Sheet 10' id='10' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' h='21369' hidden='true' id='6' story-point-id='1' type-v2='text' w='58760' x='37992' y='62448'>
          <formatted-text>
            <run bold='true' fontalignment='0'>Caption:</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>This visualization compares heart disease cases between males and females. It helps identify whether gender influences the occurrence of heart disease.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='17946' hidden='true' id='7' story-point-id='2' type-v2='text' w='40551' x='10925' y='28008'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>This chart shows the distribution of heart disease across different age groups. It highlights how the risk of heart disease changes with age.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='17946' hidden='true' id='8' story-point-id='3' type-v2='text' w='36024' x='56496' y='46680'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>This visualization compares stroke cases among diabetic and non-diabetic individuals, showing the relationship between diabetes and stroke.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='26971' hidden='true' id='9' story-point-id='4' type-v2='text' w='48622' x='49606' y='59025'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Smoking and excessive alcohol consumption are common lifestyle habits that can increase cardiovascular risk. This visualization highlights how these habits are associated with heart disease cases.</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='25250' hidden='true' id='10' story-point-id='5' type-v2='text' w='45100' x='50700' y='51500'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Pre-existing medical conditions can contribute to the likelihood of stroke. This analysis explores how different health issues are related to stroke occurrence.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='17500' hidden='true' id='11' story-point-id='6' type-v2='text' w='86700' x='3100' y='82000'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Heart disease prevalence differs across racial groups. This visualization provides a comparison that helps identify patterns among different populations.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='28875' hidden='true' id='12' story-point-id='7' type-v2='text' w='33300' x='64900' y='58375'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Individuals reporting poorer overall health tend to experience heart disease more frequently. This chart demonstrates the connection between general health status and cardiovascular conditions.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='25250' hidden='true' id='13' story-point-id='8' type-v2='text' w='60700' x='38500' y='61750'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>An active lifestyle plays an important role in maintaining heart health. This visualization compares heart disease cases based on individuals&apos; physical activity levels.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='25250' id='14' story-point-id='9' type-v2='text' w='36800' x='61400' y='71750'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Age and body mass index are important indicators in diabetes analysis. This chart reveals how these factors vary among diabetic and non-diabetic individuals.</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='28875' hidden='true' id='15' story-point-id='10' type-v2='text' w='33300' x='65500' y='69250'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>Caption:</run>
            <run fontalignment='0' lmargin='600' rmargin='600'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>Patients affected by both heart disease and diabetes are more likely to experience stroke. This visualization emphasizes the combined impact of multiple health conditions on stroke risk.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{E61614CA-ECE8-45B8-AAA4-D2EC4C90F116}' />
    </dashboard>
  </dashboards>
